  "color": {
    "navy-deep":  { "$value": "#101C38", "$description": "Fundo escuro principal (hero, header, footer)" },
    "navy":       { "$value": "#1B2A4D", "$description": "Cor institucional — títulos, wordmark, superfícies escuras" },
    "navy-soft":  { "$value": "#24365E", "$description": "Variação clara do navy para gradientes e superfícies" },
    "ink":        { "$value": "#212A3D", "$description": "Texto corrido sobre fundo claro" },
    "muted":      { "$value": "#5B6476", "$description": "Texto secundário / legendas" },
    "gold":       { "$value": "#B8933F", "$description": "Dourado base — credencial, valor, detalhes premium" },
    "gold-light": { "$value": "#DCB96A", "$description": "Dourado claro — destaques sobre fundo escuro, hover" },
    "gold-pale":  { "$value": "#F0E3C4", "$description": "Dourado pálido — faixas e fundos suaves" },
    "gold-deep":  { "$value": "#8A6A1F", "$description": "Dourado profundo — extremos de gradiente metálico" },
    "red":        { "$value": "#C8102E", "$description": "Vermelho de urgência — símbolo, selos, badges. NUNCA como cor de fundo de seção" },
    "vida-blue":  { "$value": "#1D4F91", "$description": "Azul da Estrela da Vida no símbolo oficial. Uso exclusivo do logo e ilustrações médicas" },
    "graphite":   { "$value": "#232C3D", "$description": "Contorno do hexágono do símbolo oficial" },
    "paper":      { "$value": "#FAF8F4", "$description": "Fundo claro padrão (off-white quente)" },
    "sand":       { "$value": "#ECEAE4", "$description": "Fundo neutro alternativo" },
    "white":      { "$value": "#FFFFFF" },
    "success":    { "$value": "#2E8B57", "$description": "Confirmações, 'faça'" },
    "whatsapp":   { "$value": "#25D366", "$description": "Somente no botão de WhatsApp" }
  },
  "gradient": {
    "gold-metal":  { "$value": "linear-gradient(135deg,#A07F2E,#DCB96A 55%,#B8933F)", "$description": "Botão primário e selos dourados" },
    "gold-ribbon": { "$value": "linear-gradient(90deg,#8A6A1F,#DCB96A,#8A6A1F)", "$description": "Fitas e filetes dourados (topo de página, certificado)" },
    "hero":        { "$value": "radial-gradient(1100px 520px at 78% -10%,#31456F 0%,#1B2A4D 45%,#101C38 100%)", "$description": "Fundo de hero e artes escuras" },
    "navy-card":   { "$value": "linear-gradient(160deg,#1B2A4D,#24365E)", "$description": "Cards escuros" }
  },
  "font": {
    "display": { "$value": "'Archivo', sans-serif", "$description": "Títulos, rótulos, botões — pesos 500 a 900" },
    "body":    { "$value": "'Inter', system-ui, sans-serif", "$description": "Corpo de texto e interface — pesos 400 a 700" },
    "script":  { "$value": "'Great Vibes', cursive", "$description": "USO EXCLUSIVO: palavra 'Certificado' em documentos formais" },
    "mono":    { "$value": "ui-monospace, monospace", "$description": "Códigos de credencial (ex.: MG-2025-0842)" }
  },
  "typescale": {
    "h1":      { "size": "clamp(2rem,4.6vw,3.15rem)", "family": "display", "weight": 800, "lineHeight": 1.1 },
    "h2":      { "size": "clamp(1.7rem,3.4vw,2.4rem)", "family": "display", "weight": 800, "lineHeight": 1.15 },
    "h3":      { "size": "1.22rem", "family": "display", "weight": 700, "lineHeight": 1.2 },
    "body":    { "size": "1rem", "family": "body", "weight": 400, "lineHeight": 1.6 },
    "small":   { "size": ".86rem", "family": "body", "weight": 400, "lineHeight": 1.55 },
    "eyebrow": { "size": ".78rem", "family": "display", "weight": 700, "letterSpacing": ".14em", "transform": "uppercase" },
    "label":   { "size": ".72rem", "family": "display", "weight": 700, "letterSpacing": ".1em", "transform": "uppercase" }
  },
  "radius": {
    "sm":   { "$value": "8px" },
    "md":   { "$value": "10px", "$description": "Botões" },
    "lg":   { "$value": "14px", "$description": "Cards" },
    "xl":   { "$value": "16px" },
    "pill": { "$value": "40px" }
  },
  "shadow": {
    "card":  { "$value": "0 10px 30px rgba(16,28,56,.10)" },
    "float": { "$value": "0 20px 50px rgba(16,28,56,.18)" },
    "gold":  { "$value": "0 6px 18px rgba(184,147,63,.35)", "$description": "Somente sob botão primário dourado" }
  },
  "spacing": {
    "section-desktop": { "$value": "88px" },
    "section-mobile":  { "$value": "64px" },
    "card-padding":    { "$value": "30px" },
    "container":       { "$value": "1140px" }
  },
  "formats": {
    "instagram-feed":   { "width": 1080, "height": 1080, "safeMargin": 88 },
    "instagram-story":  { "width": 1080, "height": 1920, "safeTop": 250, "safeBottom": 250 },
    "video-thumbnail":  { "width": 1280, "height": 720 },
    "certificate-a4":   { "width": 1123, "height": 794, "note": "A4 paisagem @96dpi. Página 2: conteúdo programático em tabela" }
  }
}
