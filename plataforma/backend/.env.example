DJANGO_SECRET_KEY=

# Usado só quando DJANGO_SETTINGS_MODULE=config.settings.prod (dev usa SQLite
# fixo em dev.py). Formato: mysql://usuario:senha@host:3306/nome_do_banco
DATABASE_URL=mysql://magma:senha@localhost:3306/magma

CORS_ALLOWED_ORIGINS=https://magmacursosltda.com.br
FRONTEND_URL=https://magmacursosltda.com.br
N8N_LEAD_WEBHOOK=

# Hosts que o Django aceita no cabeçalho Host (obrigatório em prod). Inclua
# o domínio e o IP externo da VPS para poder testar dos dois jeitos.
DJANGO_ALLOWED_HOSTS=magmacursosltda.com.br,203.0.113.10

# Origens confiáveis para POST/CSRF (ex.: login do admin). Precisa do
# esquema (http/https).
DJANGO_CSRF_TRUSTED_ORIGINS=https://magmacursosltda.com.br

# false enquanto testa só pelo IP sem HTTPS; true quando o domínio já tiver
# certificado TLS configurado. Ver config/settings/prod.py.
DJANGO_HTTPS_ENABLED=false
