# URL base da API Django (inclui /api). Em produção, aponta para o domínio real.
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Segredo compartilhado com o backend para acionar revalidação sob demanda
# (rota /api/revalidate no Next.js — ver doc 04-frontend-nextjs.md).
REVALIDATE_SECRET=

# Host (sem protocolo) de onde vêm as imagens em produção (media do Django,
# S3, CDN, etc.) — usado em next.config.ts para liberar o next/image.
# Ajuste para o domínio real quando a infra de mídia estiver definida.
NEXT_PUBLIC_MEDIA_HOST=media.magmacursosltda.com.br

# URL pública do site — usada em canonical/OG, JSON-LD, sitemap e robots.
NEXT_PUBLIC_SITE_URL=https://magmacursosltda.com.br

# Defina como 1 para desligar animações (equivale a ?noanim na URL).
NEXT_PUBLIC_NOANIM=
