# Copie para .env.prod e preencha antes de subir o docker-compose.prod.yml.
#   cp .env.prod.example .env.prod
#
# Fluxo recomendado: primeiro suba testando só pelo EXTERNAL_IP (sem TLS),
# depois que o DNS do DOMAIN apontar pra VPS e você configurar certificado,
# ajuste DJANGO_HTTPS_ENABLED, DJANGO_ALLOWED_HOSTS, DJANGO_CSRF_TRUSTED_ORIGINS
# e CORS_ALLOWED_ORIGINS pra incluir o domínio com https e refaça o deploy.

# --- Referência de rede (documentação / nginx / certbot futuro) -----------
DOMAIN=magmacursosltda.com.br
EXTERNAL_IP=203.0.113.10

# --- MySQL ------------------------------------------------------------
MYSQL_ROOT_PASSWORD=troque-esta-senha-root
MYSQL_DATABASE=magma
MYSQL_USER=magma
MYSQL_PASSWORD=troque-esta-senha

# --- Django (backend) ---------------------------------------------------
DJANGO_SECRET_KEY=gere-uma-chave-forte-aqui
FRONTEND_URL=http://203.0.113.10

# Host(s) aceitos no cabeçalho Host. Inclua IP e domínio, separados por
# vírgula, sem esquema (http/https) e sem porta.
DJANGO_ALLOWED_HOSTS=203.0.113.10,magmacursosltda.com.br

# Origens confiáveis pra POST/CSRF (ex.: login do dj-admin). Precisam do
# esquema. Comece só com http://IP; adicione a linha https://DOMAIN quando
# o TLS estiver pronto (pode manter as duas ao mesmo tempo).
DJANGO_CSRF_TRUSTED_ORIGINS=http://203.0.113.10

# Origens do frontend liberadas pra CORS (chamadas cross-origin à API; com
# o nginx como proxy único a maioria das chamadas já é same-origin, mas
# mantenha isto correto por segurança).
CORS_ALLOWED_ORIGINS=http://203.0.113.10

N8N_LEAD_WEBHOOK=

# false = http puro (fase de teste por IP). true = exige HTTPS (SSL
# redirect, cookies secure, HSTS) — só ligue depois que o domínio tiver
# certificado válido na frente (nginx+certbot).
DJANGO_HTTPS_ENABLED=false

# --- Next.js (frontend) — variáveis NEXT_PUBLIC_* são embutidas no build ---
# Caminho relativo: funciona igual acessando pelo IP ou pelo domínio, já
# que o nginx serve os dois na mesma origem. Não mude a menos que o
# frontend rode em host separado do backend.
NEXT_PUBLIC_API_URL=/api

# URL pública "canônica" (usada em SEO/OG/sitemap). Use o domínio quando
# já estiver disponível; até lá pode deixar apontando pro IP.
NEXT_PUBLIC_SITE_URL=http://203.0.113.10

# Host (sem protocolo) de onde vêm as imagens de mídia — usado pelo
# next/image. Com o nginx como proxy único, normalmente é o próprio
# domínio/IP.
NEXT_PUBLIC_MEDIA_HOST=magmacursosltda.com.br

# Segredo compartilhado com a rota /api/revalidate do Next.js.
REVALIDATE_SECRET=gere-um-segredo-aqui

NEXT_PUBLIC_NOANIM=
