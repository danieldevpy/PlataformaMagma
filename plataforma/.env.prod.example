# Copie para .env.prod e preencha antes de subir o docker-compose.prod.yml.
#   cp .env.prod.example .env.prod
#
# Arquitetura: nginx no HOST termina o TLS e faz proxy pros containers
# (backend 127.0.0.1:8000, frontend 127.0.0.1:3000). Frontend e backend ficam
# na mesma origem pública (https://DOMAIN), então as chamadas do navegador à
# API são same-origin (/api). O SSR do Next fala com o Django pela rede
# interna do Docker — isso é fixo no docker-compose.prod.yml (INTERNAL_API_URL),
# não precisa mexer aqui.
#
# Este exemplo já assume domínio + HTTPS (nginx + certbot) prontos. Se quiser
# validar primeiro só pelo IP em http, veja a nota em DJANGO_HTTPS_ENABLED.

# --- Referência de rede (documentação / nginx / certbot) ------------------
DOMAIN=magmacursosltda.com.br
EXTERNAL_IP=203.0.113.10

# --- MySQL ------------------------------------------------------------
MYSQL_ROOT_PASSWORD=troque-esta-senha-root
MYSQL_DATABASE=magma
MYSQL_USER=magma
MYSQL_PASSWORD=troque-esta-senha

# --- Django (backend) ---------------------------------------------------
DJANGO_SECRET_KEY=gere-uma-chave-forte-aqui
FRONTEND_URL=https://magmacursosltda.com.br

# Host(s) aceitos no cabeçalho Host. Sem esquema (http/https) e sem porta,
# separados por vírgula. Inclua o www se for usar.
DJANGO_ALLOWED_HOSTS=magmacursosltda.com.br,www.magmacursosltda.com.br

# Origens confiáveis pra POST/CSRF (ex.: login do dj-admin). Precisam do
# esquema. Com HTTPS na frente, use https://.
DJANGO_CSRF_TRUSTED_ORIGINS=https://magmacursosltda.com.br,https://www.magmacursosltda.com.br

# Origens do frontend liberadas pra CORS. Com o nginx como origem única a
# maioria das chamadas já é same-origin, mas mantenha correto por segurança.
CORS_ALLOWED_ORIGINS=https://magmacursosltda.com.br,https://www.magmacursosltda.com.br

N8N_LEAD_WEBHOOK=

# true = exige HTTPS (cookies secure, HSTS). Correto quando o nginx do host
# já serve o domínio com certificado válido — é o caso deste exemplo. O
# redirect http->https é feito pelo nginx; o Django reconhece o tráfego como
# seguro pelo X-Forwarded-Proto (SECURE_PROXY_SSL_HEADER).
#   Só coloque false se for testar temporariamente por http://IP sem TLS
#   (aí ajuste ALLOWED_HOSTS/CSRF/CORS/URLs abaixo pra http://IP também).
DJANGO_HTTPS_ENABLED=true

# --- Next.js (frontend) — variáveis NEXT_PUBLIC_* são embutidas no build ---
# Caminho relativo: o navegador chama a API na mesma origem, via nginx. Não
# mude a menos que o frontend rode em host separado do backend.
NEXT_PUBLIC_API_URL=/api

# URL pública "canônica" (SEO/OG/sitemap).
NEXT_PUBLIC_SITE_URL=https://magmacursosltda.com.br

# Host (sem protocolo) de onde o next/image pode buscar mídia. Com o nginx
# servindo /media/ no próprio domínio, é o próprio domínio. (As URLs de mídia
# vindas da API são relativas, então isto é só o allowlist de fallback.)
NEXT_PUBLIC_MEDIA_HOST=magmacursosltda.com.br

# Segredo compartilhado com a rota /api/revalidate do Next.js.
REVALIDATE_SECRET=gere-um-segredo-aqui

NEXT_PUBLIC_NOANIM=
